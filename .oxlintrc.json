{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "unicorn"],
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "perf": "warn",
    "restriction": "off",
    "pedantic": "off",
    "style": "off"
  },
  "env": {
    "builtin": true
  },
  "ignorePatterns": ["node_modules", "dist", "src/db/migrations"]
}
